# Mock Payer Simulator Configuration
# Copy this file to .env and fill in your values

# Set to 1 to enable real OpenAI LLM (understands vague questions)
# Set to 0 to use mock LLM (requires clear questions from the list)
USE_REAL_LLM=0

# OpenAI API key (required when USE_REAL_LLM=1)
OPENAI_API_KEY=sk-your-key-here
